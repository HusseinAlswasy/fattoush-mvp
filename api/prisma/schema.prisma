generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  DRIVER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  ASSIGNED
  PICKED_UP
  ON_THE_WAY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CARD
  COD
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYMOB
  CASH
}

enum DeliveryStatusUpdate {
  PICKED_UP
  ON_THE_WAY
  DELIVERED
}

model User {
  id                 String           @id @default(uuid())
  role               UserRole         @default(CUSTOMER)
  name               String?
  email              String?          @unique
  phone              String?          @unique
  passwordHash       String
  favorites          Favorite[]
  customerOrders     Order[]          @relation("CustomerOrders")
  assignedOrders     Order[]          @relation("AssignedDriver")
  driverLocations    DriverLocation[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Product {
  id          String      @id @default(uuid())
  name        String
  category    String      @default("Other")
  description String?
  price       Decimal     @db.Decimal(10, 2)
  imageUrl    String?
  isActive    Boolean     @default(true)
  favorites   Favorite[]
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Order {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation("CustomerOrders", fields: [userId], references: [id], onDelete: Cascade)
  status           OrderStatus    @default(PENDING)
  paymentMethod    PaymentMethod
  paymentStatus    PaymentStatus  @default(UNPAID)
  subtotal         Decimal        @db.Decimal(10, 2)
  deliveryFee      Decimal        @db.Decimal(10, 2)
  total            Decimal        @db.Decimal(10, 2)
  addressText      String
  lat              Decimal?       @db.Decimal(10, 7)
  lng              Decimal?       @db.Decimal(10, 7)
  assignedDriverId String?
  assignedDriver   User?          @relation("AssignedDriver", fields: [assignedDriverId], references: [id])
  items            OrderItem[]
  payments         Payment[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
  unitPrice Decimal  @db.Decimal(10, 2)
  quantity  Int
  lineTotal Decimal  @db.Decimal(10, 2)
}

model Payment {
  id                String          @id @default(uuid())
  orderId           String
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider          PaymentProvider
  providerPaymentId String?
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("AED")
  status            PaymentStatus   @default(UNPAID)
  createdAt         DateTime        @default(now())
}

model AdsBanner {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  productId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model DriverLocation {
  id        String   @id @default(uuid())
  driverId  String   @unique
  driver    User     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  lat       Decimal  @db.Decimal(10, 7)
  lng       Decimal  @db.Decimal(10, 7)
  updatedAt DateTime @updatedAt
}
